/*
    Nama file : contoh.nusa
    Fungsi file : sebagai contoh untuk sintaks bahasa pemrograman nusantara
*/

// Fungsi yang akan di panggil saat pertamakali program dijalankan.
awal() {
    // Membuat variable dengan tipe teks
    teks nama = 'Fern Aerell';
    // Membuat variable dengan tipe bilangan
    bilangan umur = 1,9;
    // Mencetak teks interpolasi ke konsol
    cetak('Nama saya $nama, umur saya $umur tahun.');
}